{
  "name": "banyanvision-backend",
  "version": "1.0.0",
  "description": "BanyanVision Fashion - REST API Backend",
  "main": "server.js",
  "scripts": {
    "start": "node --no-deprecation server.js",
    "dev": "nodemon --no-deprecation --signal SIGTERM server.js",
    "db:status": "node db-sync.js status",
    "db:push:safe": "node db-sync.js push --safe",
    "db:push:all": "node db-sync.js push --all",
    "db:pull:all": "node db-sync.js pull --all",
    "db:push": "node db-sync.js push",
    "db:pull": "node db-sync.js pull",
    "check": "node start-check.js",
    "prod": "pm2 start server.js --name banyanvision-api --restart-delay=3000 --max-restarts=10",
    "prod:stop": "pm2 stop banyanvision-api",
    "prod:logs": "pm2 logs banyanvision-api",
    "prod:status": "pm2 status"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.8",
    "razorpay": "^2.9.2",
    "resend": "^3.2.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes.js",
      "models.js",
      "middleware.js",
      "mailer.js"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/"
    ],
    "delay": "1000",
    "signal": "SIGTERM"
  }
}
