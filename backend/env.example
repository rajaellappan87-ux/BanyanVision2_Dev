# ─────────────────────────────────────────────────────────────────────────────
# BanyanVision — Environment Variables
# Copy to .env for local dev | Set in Railway dashboard for production
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/banyanvision_dev?retryWrites=true&w=majority
MONGO_URI_DEV=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/banyanvision_dev?retryWrites=true&w=majority
MONGO_URI_PROD=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/banyanvision_prod?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_40plus_char_random_secret_here
JWT_EXPIRE=7d

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — choose ONE provider
# ─────────────────────────────────────────────────────────────────────────────

# OPTION A: Resend (RECOMMENDED for Railway — free 3000 emails/month)
# Sign up at resend.com → create API key → add domain
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="BanyanVision" <noreply@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com

# OPTION B: Zoho SMTP (works in localhost, blocked by Railway on ports 465/587)
# EMAIL_PROVIDER=zoho
# SMTP_HOST=smtppro.zoho.in
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=admin@yourdomain.com
# SMTP_PASS=your_zoho_app_password
# EMAIL_FROM="BanyanVision" <admin@yourdomain.com>
# ADMIN_EMAIL=admin@yourdomain.com

# OPTION C: SendGrid (free 100 emails/day)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="BanyanVision" <noreply@yourdomain.com>
# ADMIN_EMAIL=admin@yourdomain.com

# ── Frontend URL ──────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
